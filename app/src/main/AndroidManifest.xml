<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Storage: READ_MEDIA_* for API 33+, READ_EXTERNAL_STORAGE for API 29-32 -->
    <uses-permission android:name="android.permission.READ_MEDIA_VIDEO"                                                                              android:minSdkVersion="33" />
    <uses-permission android:name="android.permission.READ_MEDIA_IMAGES"
        android:minSdkVersion="33" />
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE"
        android:maxSdkVersion="32" />
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE"
        android:maxSdkVersion="29" />

    <!-- Hardware acceleration required for GPU compositing -->
    <uses-feature android:name="android.hardware.opengles.version"
        android:glEsVersion="0x00030000"
        android:required="true" />

    <application
        android:allowBackup="false"                                                                                                                  android:hardwareAccelerated="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:largeHeap="false"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.VBR">

        <!-- largeHeap=false intentionally — we manage memory ourselves via FramePool.
             Relying on largeHeap masks leaks and causes worse GC pauses. -->

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:screenOrientation="portrait"
            android:windowSoftInputMode="adjustResize">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>

            <!-- Allow importing video files from other apps -->
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:mimeType="video/*" />
            </intent-filter>
        </activity>

    </application>

</manifest>

